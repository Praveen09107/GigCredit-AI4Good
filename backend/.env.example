# Local MongoDB:
# MONGO_URI=mongodb://localhost:27017
# MongoDB Atlas SRV format:
# MONGO_URI=mongodb+srv://<username>:<db_password>@cluster0.3ydbumb.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=gigcredit
API_KEY=replace_with_secure_key
GEMINI_API_KEY=
HMAC_REPLAY_WINDOW_SECONDS=300
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_ENDPOINT_PER_MINUTE=10
RATE_LIMIT_BURST_PER_SECOND=5
